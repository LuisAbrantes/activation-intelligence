# ─── Variáveis do Servidor (Vercel) ──────────────────────────────────────────
# Essas ficam nas Environment Variables do Vercel, NUNCA no bundle do browser.

# Chave da API do Groq (https://console.groq.com/keys)
GROQ_KEY=

# Chave da API da AbacatePay do merchant
ABACATE_KEY=

# ─── Variáveis do Client (prefixo VITE_) ────────────────────────────────────
# Essas SÃO incluídas no bundle — não coloque nada sensível aqui.

# Ativar proxy Vercel para evitar CORS em produção (true | false)
VITE_USE_PROXY=false
